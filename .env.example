# SMTP for sending contact form emails (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Platform launchpad at /launchpad
# Leave empty to use this deployment's same-origin /api routes.
NEXT_PUBLIC_API_URL=
DATABASE_URL=postgresql://user:password@host:5432/ip_foundation?sslmode=require
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_FACTORY_ADDRESS=0x3e094bcdc1777f0a0067fe7ecf7752d48df978a6
FACTORY_DEPLOY_BLOCK=0
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id
ADMIN_PASSWORD=change-me
COMPANY_AUTH_SECRET=replace-with-a-long-random-secret
INDEXER_SYNC_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
